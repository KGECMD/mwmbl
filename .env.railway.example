# =============================================================================
# MWMBL Railway Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# =============================================================================
# Required Variables
# =============================================================================

# Django secret key - generate a secure random key for production
DJANGO_SECRET_KEY=your-super-secret-django-key-change-in-production

# Database URL - Railway PostgreSQL provides this automatically
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis URL - Railway Redis provides this automatically
# REDIS_URL=redis://host:6379

# =============================================================================
# Domain Settings (CRITICAL for email confirmation)
# =============================================================================

# The public domain where your app is hosted (auto-set by Railway)
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app

# Your custom domain (if using one)
# SITE_DOMAIN=https://mwmbl.org

# Account confirmation URL - where users confirm their email
# This MUST be set to your frontend domain for email verification to work
# Example: https://mwmbl.org/confirm-email
ACCOUNT_CONFIRMATION_URL=https://mwmbl.org/confirm-email

# =============================================================================
# Optional: Override Settings
# =============================================================================

# Set to true for production
DEBUG=false

# Log level
LOG_LEVEL=INFO

# =============================================================================
# MWMBL Application Settings
# =============================================================================

# S3 Storage for crawl data
MWMBL_APPLICATION_KEY=
MWMBL_KEY_ID=
MWMBL_ENDPOINT_URL=https://s3.amazonaws.com
MWMBL_BUCKET_NAME=mwmbl-crawl

# Data paths (defaults work for Railway)
# MWMBL_DATA_PATH=/app/storage
# MWMBL_INDEX_NAME=index-v2.tinysearch

# =============================================================================
# Email Configuration
# =============================================================================

# SendGrid or other SMTP provider
EMAIL_HOST_PASSWORD=
# Or use alternative backend
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# =============================================================================
# Sentry Error Tracking (Optional)
# =============================================================================

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# Polar Billing (Optional)
# =============================================================================

POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID_STARTER=
POLAR_PRODUCT_ID_PRO=
POLAR_SERVER=production

# =============================================================================
# Feature Flags
# =============================================================================

# Set to true to enable maintenance mode
MAINTENANCE_MODE=false

# =============================================================================
# Railway-specific (auto-set by Railway)
# =============================================================================

# RAILWAY_GIT_COMMIT_SHA=abc123
# RAILWAY_ENVIRONMENT=production

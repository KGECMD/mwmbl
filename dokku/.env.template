# =============================================================================
# MWMBL Environment Variables for Dokku
# =============================================================================
# Copy this file to .env.dokku and set your values

# =============================================================================
# Required Variables
# =============================================================================

# Django secret key - generate a secure random key for production
DJANGO_SECRET_KEY=your-super-secret-django-key-change-in-production

# Set to false in production
DEBUG=false

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL - Set by Dokku automatically if using postgres plugin
# DATABASE_URL=postgres://user:password@host:5432/dbname

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis URL - Set by Dokku automatically if using redis plugin
# REDIS_URL=redis://host:6379

# =============================================================================
# MWMBL Application Settings
# =============================================================================

# Data storage path
MWMBL_DATA_PATH=/app/storage

# Search index name
MWMBL_INDEX_NAME=index-v2.tinysearch

# Number of URL characters in bloom filter
NUM_URLS_IN_BLOOM_FILTER=100000000

# =============================================================================
# Email Configuration
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=MWMBL <noreply@mwmbl.org>

# =============================================================================
# Sentry Error Tracking (Optional)
# =============================================================================

# SENTRY_DSN=

# =============================================================================
# Polar Billing (Optional)
# =============================================================================

# POLAR_ACCESS_TOKEN=
# POLAR_WEBHOOK_SECRET=
# POLAR_PRODUCT_ID_STARTER=
# POLAR_PRODUCT_ID_PRO=
# POLAR_SERVER=production

# =============================================================================
# Feature Flags
# =============================================================================

ENABLE_SUPER_SEARCH=true
ENABLE_VOTING=true

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO

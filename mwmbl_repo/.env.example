# Mwmbl environment variables — copy to .env (Dokku: `dokku config:set MWMBL_APP VAR=value`)
#
# These are the variables read by `mwmbl-tinysearchengine` and `mwmbl-crawl`.
# Anything uncommented in `app.json` / kubernetes manifests / Dokku config is also
# read. Use this file as a checklist when provisioning a new environment.
#
# DO NOT commit a real .env with secrets. Use Dokku config or a secrets manager.
################################################################################

# ---- Core / runtime --------------------------------------------------------
# Which mode the tinysearchengine container runs in. Required.
# One of: server | update_urls | update_batches | copy_indexes | count_urls
# In Dokku, use a separate app instance per worker type or a Procfile entry.
MWMBL_APP=server

# Django secret key. Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-with-a-long-random-string

# PostgreSQL connection. Required for server, update_urls, copy_indexes, count_urls.
# Format: postgres://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=postgres://mwmbl:CHANGEME@db:5432/mwmbl

# Redis connection for cache and queues. Required for all apps.
REDIS_URL=redis://redis:6379

# ---- Crawler-only ----------------------------------------------------------
# API key for pushing batched crawl results to the public Mwmbl index.
# Obtain from your Mwmbl account (see book.mwmbl.org for the crawler flow).
MWMBL_API_KEY=

# Contact info embedded in the crawler's User-Agent so site admins can reach
# you if there are crawl problems. Email or URL.
MWMBL_CONTACT_INFO=contact@example.com

# ---- Observability ---------------------------------------------------------
# Optional. If unset, Sentry is skipped (see settings_common.py).
SENTRY_DSN=

# ---- Email (account verification, transactional) ---------------------------
# Sendgrid in production. Override locally if needed.
EMAIL_HOST_PASSWORD=apikey-from-sendgrid

# ---- Payments (Polar.sh — for Sponsorship / Starter / Pro tiers) -----------
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID_STARTER=
POLAR_PRODUCT_ID_PRO=
# "sandbox" or "production"
POLAR_SERVER=sandbox

# ---- CORS / privacy toggles (see settings_common.py) -----------------------
# When true (default), never store query strings or PII in Sentry events.
Django Sentry default `send_default_pii=False`, query-string strip — already on.

# ---- Dokku-only knobs ------------------------------------------------------
# Pre-deploy hook (`app.json`) copies the front-end dist into /app/static/.
# Set FORCE_HTTPS=1 only after TLS certificates are installed by Dokku.
